# ============================================
# Supabase (server + browser)
# Set in Vercel → Project → Settings → Environment Variables
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key   # server-only, never exposed to client

# ============================================
# Notifications (server-only)
# Resend.com — simple transactional email
# ============================================
RESEND_API_KEY=re_...                          # leave empty to disable email
NOTIFY_TO_EMAIL=info@leventmarinetech.com      # where RFQ/service notifications go
NOTIFY_FROM_EMAIL=Levent Marine <noreply@leventmarinetech.com>

# ============================================
# Site URL (used in emails, SEO, canonical)
# ============================================
NEXT_PUBLIC_SITE_URL=https://leventmarinetech.com

# ============================================
# Supply catalog providers (server-only)
# /api/supply-search calls every configured provider in parallel and
# dedupes the merged list. Each one is independent — adding more
# improves catalog quality without changing the UI.
# Verify configuration at /api/sources-status after each change.
# ============================================

# eBay Browse API — marketplace, peer-to-peer sellers
EBAY_APP_ID=                                   # Production Client ID
EBAY_CERT_ID=                                  # Production Client Secret — SECRET, never log
EBAY_MARKETPLACE_ID=EBAY_US                    # optional; EBAY_US is the default
EBAY_ENV=production                            # 'production' or 'sandbox'

# Mouser Electronics — catalog distributor, single price per part
# Sign up: https://developer.mouser.com (free, instant approval)
MOUSER_API_KEY=                                # one key, no OAuth

# Digi-Key Product Information API v4 — catalog distributor
# Sign up: https://developer.digikey.com (OAuth2 client credentials)
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_LOCALE=en,US,USD                       # optional; lang,site,currency
DIGIKEY_ENV=production                         # 'production' or 'sandbox'

# Grainger Business API — US industrial supply distributor
# Sign up: https://www.grainger.com/business (KeepStock / B2B approval)
GRAINGER_API_KEY=
GRAINGER_ACCOUNT=                              # your business account number

# ============================================
# Optional analytics + SEO verification
# ============================================
NEXT_PUBLIC_GA4_ID=                            # G-XXXXXXXXXX  (empty disables GA4)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=                  # leventmarinetech.com  (empty disables Plausible)
NEXT_PUBLIC_GSC_VERIFICATION=                  # Google Search Console: paste only the content string
