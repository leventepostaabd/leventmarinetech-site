# ============================================
# Supabase (server + browser)
# Set in Vercel → Project → Settings → Environment Variables
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key   # server-only, never exposed to client

# ============================================
# Notifications (server-only)
# Resend.com — simple transactional email
# ============================================
RESEND_API_KEY=re_...                          # leave empty to disable email
NOTIFY_TO_EMAIL=info@leventmarinetech.com      # where RFQ/service notifications go
NOTIFY_FROM_EMAIL=Levent Marine <noreply@leventmarinetech.com>

# ============================================
# Site URL (used in emails, SEO, canonical)
# ============================================
NEXT_PUBLIC_SITE_URL=https://leventmarinetech.com

# ============================================
# eBay Browse API (server-only, supply catalog live search)
# When set, /api/supply-search returns live eBay results merged with
# the local seed catalog. Prices are stripped on render.
# ============================================
EBAY_APP_ID=                                   # Production Client ID (LeventDe-LeventMa-PRD-...)
EBAY_CERT_ID=                                  # Production Client Secret — SECRET, never log
EBAY_MARKETPLACE_ID=EBAY_US                    # optional; EBAY_US is the default
EBAY_ENV=production                            # 'production' or 'sandbox'

# ============================================
# Optional analytics
# ============================================
NEXT_PUBLIC_GA4_ID=                            # G-XXXXXXXXXX  (empty disables)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=                  # leventmarinetech.com  (empty disables)
